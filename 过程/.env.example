# Anthropic API Key (必填 - 用于AI分析功能)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# AI模型配置（可选）
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# 缓存TTL（秒）- 可选
CACHE_TTL_ANALYSIS=604800
CACHE_TTL_QA=3600

# 服务器配置（可选）
SERVER_HOST=127.0.0.1
SERVER_PORT=5000
DEBUG=false

# 种子数据（可选）
AUTO_SEED=true

# Flask密钥（可选）
SECRET_KEY=change-me-in-production
